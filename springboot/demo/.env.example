# =============================================
# .env.example - Farmacia María Rosa Backend
# =============================================
# INSTRUCCIONES:
# 1. Copia este archivo y renómbralo a ".env"
# 2. Completa los valores reales (solo para desarrollo local)
# 3. NUNCA subas el archivo ".env" a GitHub
# 4. En producción (Render), configura estas variables directamente
#    en el panel: Dashboard > Service > Environment
# =============================================

# ---- Base de datos ----
# URL JDBC para PostgreSQL local.
# En Render, el Blueprint inyecta host, puerto, base y credenciales directamente.
DB_URL=

# Credenciales de PostgreSQL
DB_USERNAME=
DB_PASSWORD=

# ---- Spring Boot ----
SPRING_PROFILES_ACTIVE=
DDL_AUTO=
SHOW_SQL=

# ---- JWT ----
# Clave secreta BASE64 de al menos 256 bits
# Generar con: openssl rand -base64 64
JWT_SECRET=

# ---- CORS ----
# URL del frontend desplegado (Vercel o Render)
# Ejemplo: https://farmacia-maria-rosa.vercel.app
FRONTEND_URL=

# ---- Administrador por defecto ----
ADMIN_EMAIL=
ADMIN_PASSWORD=
CREATE_DEFAULT_ADMIN=

# ---- Chatbot (Groq) ----
# Obtener en: https://console.groq.com
GROQ_API_KEY=
