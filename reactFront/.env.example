# =============================================
# .env.example - Farmacia María Rosa (React Frontend)
# =============================================
# INSTRUCCIONES:
# 1. Copia este archivo y renómbralo a ".env.local"
# 2. Para desarrollo local, el proxy de Vite ya redirige las peticiones /api
#    automáticamente a localhost:8081, por lo que no necesitas configurar nada.
# 3. Para Vercel en producción: configurar en el panel de Vercel
#    Dashboard > Project > Settings > Environment Variables
# =============================================

# URL completa del backend en producción (Render)
# Ejemplo: https://farmacia-maria-rosa-backend.onrender.com
# En desarrollo local, dejar vacío (se usa el proxy de Vite)
VITE_API_URL=
